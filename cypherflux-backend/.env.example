# CypherFlux Backend Environment
# Copy this file to .env (same folder) and fill values.

# --- Flask ---
SECRET_KEY=change-me
JWT_SECRET_KEY=change-me

# OTP hashing secret (optional). If unset, SECRET_KEY is used.
OTP_SECRET=change-me

# OTP behavior
# OTP_EXPIRY_SECONDS=300
# OTP_RESEND_COOLDOWN_SECONDS=30

# --- Database (choose ONE option) ---
# Option A (recommended): full SQLAlchemy URL using psycopg (Postgres)
# DATABASE_URL=postgresql+psycopg://postgres:YOUR_PASSWORD@localhost:5432/Cypherflux

# Option B: individual parts (the app will assemble a URL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=Cypherflux
DB_USER=postgres
# DB_PASSWORD=YOUR_PASSWORD

# --- Email (Gmail SMTP) ---
# Use an App Password (recommended), not your normal Gmail password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
# SMTP_USERNAME=your_gmail@gmail.com
# SMTP_PASSWORD=your_gmail_app_password

# Additional email recipients for OTP verification (comma-separated, optional)
# OTP will be sent to the user's email AND these additional emails
# OTP_RECIPIENT_EMAILS=admin@example.com,support@example.com

